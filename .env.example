# Frontend: backend API URL for production builds (leave empty for local dev proxy)
VITE_API_URL=

# Local dev only: where Vite proxies /api requests
VITE_API_PROXY_TARGET=http://localhost:3001

# GEMINI_API_KEY: Required for Gemini AI API calls (optional for this app).
GEMINI_API_KEY="MY_GEMINI_API_KEY"
