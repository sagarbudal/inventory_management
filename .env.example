# =============================================================================
# FRONTEND — Environment variables
# Copy to .env.local for local development (see .env.local.example)
# =============================================================================

# Production (Vercel): REQUIRED — your Render backend origin (no trailing slash)
# Example: https://inventory-management-api.onrender.com
VITE_API_URL=

# Local dev only: Vite dev-server proxy target (backend must be running)
VITE_API_PROXY_TARGET=http://localhost:3001

# Optional — only if using Gemini features in the frontend
GEMINI_API_KEY=
