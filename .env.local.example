# =============================================================================
# FRONTEND — Local development (.env.local)
# Copy to: .env.local (project root)
# =============================================================================

# Leave empty to use Vite dev proxy (/api → backend)
VITE_API_URL=

# Backend URL for Vite proxy (local only)
VITE_API_PROXY_TARGET=http://localhost:3001

# Optional — not required for core inventory features
GEMINI_API_KEY=
