# =============================================================================
# BACKEND — Local development
# Copy to: backend/.env
# =============================================================================

MONGODB_URI=mongodb://USER:PASSWORD@host1:27017,host2:27017,host3:27017/inventory_management?ssl=true&authSource=admin&retryWrites=true&w=majority
MONGODB_URI_DIRECT=
PORT=3001
FRONTEND_URL=http://localhost:5173

# =============================================================================
# BACKEND — Render production
# Set in: Render Dashboard → Service → Environment
# =============================================================================
# MONGODB_URI= (same as above — use direct URI if mongodb+srv fails on Windows)
# MONGODB_URI_DIRECT= (optional fallback)
# FRONTEND_URL=https://YOUR-APP.vercel.app
# PORT= (Render sets automatically — do not override)
# HOST=0.0.0.0 (optional — default)
#
# Render Build Command: npm run render-build
# Render Start Command: npm start
